{
	"name": "nextcloud/objectstore_cache",
	"description": "Read-through cache and retry wrapper for the S3 primary object store",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "CVan"
		}
	],
	"require": {
		"php": "^8.1"
	},
	"require-dev": {
		"aws/aws-sdk-php": "^3.0",
		"nextcloud/coding-standard": "^1.3",
		"nextcloud/ocp": "dev-master",
		"phpunit/phpunit": "^10.5",
		"vimeo/psalm": "^5.26"
	},
	"scripts": {
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"lint": "find . -name '*.php' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
		"psalm": "psalm --threads=1 --no-cache",
		"test:unit": "phpunit --configuration tests/phpunit.xml"
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true
	},
	"autoload": {
		"psr-4": {
			"OCA\\ObjectStoreCache\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\ObjectStoreCache\\Tests\\": "tests/"
		}
	}
}
